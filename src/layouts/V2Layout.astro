---
import '../styles/global.css';
import SideNavV2 from '../components/v2/SideNavV2.astro';
import FloatingCtaV2 from '../components/v2/FloatingCtaV2.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="description"
      content="BUNKERGYM by Giovifitness — Protocolo Xtreme: entrenamiento crudo, resultados reales. Versión alternativa de diseño."
    />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Archivo:ital,wght@0,400;0,700;0,800;0,900;1,700&family=Space+Mono:wght@400;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-paper text-void font-display antialiased selection:bg-acid selection:text-acid-ink">
    <div class="scroll-progress !bg-none !bg-acid" data-scroll-progress></div>
    <SideNavV2 />
    <slot />
    <FloatingCtaV2 />

    <script>
      import { gsap } from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';

      gsap.registerPlugin(ScrollTrigger);

      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (!reduceMotion) {
        document.documentElement.classList.add('bunker-motion');

        const reveals = gsap.utils.toArray<HTMLElement>('[data-reveal]');
        reveals.forEach((el) => {
          const delay = (Number(el.dataset.revealIndex) || 0) * 0.09;
          gsap.to(el, {
            opacity: 1,
            y: 0,
            scale: 1,
            duration: 0.8,
            ease: 'expo.out',
            delay,
            scrollTrigger: { trigger: el, start: 'top 85%', toggleActions: 'play none none none' },
          });
        });

        const imgReveals = gsap.utils.toArray<HTMLElement>('[data-reveal-img]');
        imgReveals.forEach((el) => {
          const inner = el.querySelector('img');
          const tl = gsap.timeline({
            scrollTrigger: { trigger: el, start: 'top 85%', toggleActions: 'play none none none' },
          });
          tl.to(el, { clipPath: 'inset(0 0 0% 0)', duration: 1, ease: 'expo.out' });
          if (inner) tl.to(inner, { scale: 1, duration: 1.5, ease: 'power2.out' }, 0);
        });

        // Hero: pin + escala/fade cinético del titular al iniciar el scroll
        const hero = document.querySelector<HTMLElement>('[data-hero]');
        const headline = hero?.querySelector<HTMLElement>('[data-hero-headline]');
        if (hero && headline) {
          ScrollTrigger.create({ trigger: hero, start: 'top top', end: '+=55%', pin: true, pinSpacing: true });
          gsap.to(headline, {
            scale: 0.82,
            opacity: 0.25,
            yPercent: -12,
            ease: 'none',
            scrollTrigger: { trigger: hero, start: 'top top', end: '+=55%', scrub: true },
          });
        }

        // Spotlight de cursor sobre secciones oscuras
        gsap.utils.toArray<HTMLElement>('[data-spotlight]').forEach((section) => {
          const glow = section.querySelector<HTMLElement>('[data-spotlight-glow]');
          if (!glow || !window.matchMedia('(pointer: fine)').matches) return;
          section.addEventListener('mousemove', (e: MouseEvent) => {
            const rect = section.getBoundingClientRect();
            gsap.to(glow, {
              left: e.clientX - rect.left,
              top: e.clientY - rect.top,
              opacity: 1,
              duration: 0.5,
              ease: 'power2.out',
            });
          });
          section.addEventListener('mouseleave', () => {
            gsap.to(glow, { opacity: 0, duration: 0.6 });
          });
        });

        // Barra de progreso de scroll
        const progress = document.querySelector<HTMLElement>('[data-scroll-progress]');
        if (progress) {
          gsap.to(progress, {
            width: '100%',
            ease: 'none',
            scrollTrigger: { start: 0, end: () => document.body.scrollHeight - window.innerHeight, scrub: true },
          });
        }
      }

      // Count-up — respeta reduced motion (valor final inmediato)
      const counters = gsap.utils.toArray<HTMLElement>('[data-count-to]');
      counters.forEach((el) => {
        const target = Number(el.dataset.countTo || '0');
        if (reduceMotion) {
          el.textContent = target.toLocaleString('es-PE');
          return;
        }
        const counter = { val: 0 };
        ScrollTrigger.create({
          trigger: el,
          start: 'top 85%',
          once: true,
          onEnter: () => {
            gsap.to(counter, {
              val: target,
              duration: 1.4,
              ease: 'power2.out',
              onUpdate: () => {
                el.textContent = Math.round(counter.val).toLocaleString('es-PE');
              },
            });
          },
        });
      });

      // Header: transparente sobre el hero, --paper al hacer scroll
      const header = document.querySelector('[data-site-header]');
      if (header) {
        ScrollTrigger.create({
          trigger: document.body,
          start: 'top -80',
          onEnter: () => header.classList.add('is-scrolled'),
          onLeaveBack: () => header.classList.remove('is-scrolled'),
        });
      }
    </script>
  </body>
</html>
