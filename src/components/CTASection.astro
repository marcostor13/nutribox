---
import { Icon } from 'astro-icon/components';
---

<section class="py-24 bg-slate-900 border-t-8 border-green-500 relative overflow-hidden">
  <!-- Glowing background effect -->
  <div class="absolute inset-0 z-0">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-green-500/10 rounded-full blur-[100px]"></div>
  </div>

  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center relative z-10">
    <h2 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-white mb-8 leading-tight">
      Empieza <span class="text-transparent bg-clip-text bg-gradient-to-r from-green-400 to-emerald-400">Hoy</span> tu Transformación
    </h2>
    
    <div class="flex flex-col sm:flex-row justify-center items-center gap-6 mb-12 text-slate-300">
      <div class="flex items-center gap-2 text-lg">
        <Icon name="lucide:check-circle-2" class="w-6 h-6 text-green-400" />
        <span>Recibe tu primera Nutribox</span>
      </div>
      <div class="flex items-center gap-2 text-lg hidden sm:flex text-slate-600">|</div>
      <div class="flex items-center gap-2 text-lg lg:col-span-1">
        <Icon name="lucide:check-circle-2" class="w-6 h-6 text-green-400" />
        <span>Siente el cambio desde el primer mes</span>
      </div>
    </div>

    <button class="payment-btn group relative inline-flex items-center justify-center px-10 py-5 text-xl font-bold text-slate-900 bg-gradient-to-r from-green-400 to-emerald-500 rounded-full overflow-hidden shadow-[0_0_40px_rgba(7ade80,0.4)] hover:shadow-[0_0_60px_rgba(7ade80,0.6)] hover:scale-105 transition-all duration-300">
      <div class="absolute inset-0 w-full h-full bg-white/20 group-hover:animate-[shimmer_1.5s_infinite] -translate-x-full"></div>
      <span class="mr-3">QUIERO MI NUTRIBOX AHORA</span>
      <Icon name="lucide:mouse-pointer-click" class="w-6 h-6 animate-pulse" />
    </button>
    
    <p class="mt-8 text-slate-400 italic text-lg max-w-2xl mx-auto">
      "No es solo una caja, es el inicio de una relación de amor propio que siempre debiste tener."
    </p>
  </div>
</section>
