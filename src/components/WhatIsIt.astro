---
import { Icon } from 'astro-icon/components';

const features = [
  {
    icon: "lucide:cookie",
    title: "Snacks Saludables",
    description: "Antojos sin culpa para calmar el hambre entre comidas de forma inteligente.",
    color: "bg-amber-100 text-amber-600"
  },
  {
    icon: "lucide:beef",
    title: "Alta Proteína",
    description: "Productos seleccionados para ayudarte a mantener y ganar masa muscular.",
    color: "bg-red-100 text-red-600"
  },
  {
    icon: "lucide:wheat-off",
    title: "Sin Azúcar y Sin Gluten",
    description: "Opciones seguras y deliciosas que cuidan tu digestión y tus niveles de energía.",
    color: "bg-blue-100 text-blue-600"
  },
  {
    icon: "lucide:sparkles",
    title: "Sorpresas Fitness",
    description: "Accesorios, suplementos o herramientas que elevan tu estilo de vida activo.",
    color: "bg-purple-100 text-purple-600"
  }
];
---

<section id="que-es" class="py-20 bg-slate-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-green-600 font-bold tracking-wider uppercase text-sm mb-3">Descubre la Experiencia</h2>
      <h3 class="text-3xl md:text-4xl font-extrabold text-slate-800 mb-6">
        ¿Qué es <span class="text-transparent bg-clip-text bg-gradient-to-r from-green-600 to-green-400">Nutribox?</span>
      </h3>
      <p class="text-lg text-slate-600">
        Nutribox es una caja saludable sorpresa con productos premium seleccionados mes a mes para ayudarte a verte y sentirte increíble sin caer en la monotonía.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      {features.map(feature => (
        <div class="bg-white rounded-3xl p-8 shadow-sm hover:shadow-xl transition-shadow duration-300 border border-slate-100 group">
          <div class={`w-14 h-14 rounded-2xl flex items-center justify-center mb-6 ${feature.color} group-hover:scale-110 transition-transform`}>
            <Icon name={feature.icon} class="w-7 h-7" />
          </div>
          <h4 class="text-xl font-bold text-slate-800 mb-3">{feature.title}</h4>
          <p class="text-slate-600 leading-relaxed">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
