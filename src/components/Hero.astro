---
import { Icon } from 'astro-icon/components';

/* 
Hormozi Principle (Value Equation):
Dream Outcome: Físico que deseas, sentirte increíble.
Perceived Likelihood: Productos seleccionados, opciones premium.
Time Delay: Cada mes (Siente el cambio desde el primer mes).
Effort/Sacrifice: Sin aburrirte, sin pensar (práctica, divertida).
*/

// Variation A pushes more on the outcome and lack of effort
const variationA = {
  headline: "Consigue el Físico que Deseas Comiendo Saludable Sin Aburrirte.",
  subheadline: "Tu Nutribox mensual con snacks premium y opciones fitness para transformar tu energía y tu vida, sin dietas restrictivas.",
  cta: "QUIERO MI NUTRIBOX AHORA",
};
---

<section class="relative bg-white overflow-hidden pt-24 pb-16 lg:pt-32 lg:pb-24">
  <!-- Interactive background decoration -->
  <div class="absolute inset-0 z-0">
    <div class="absolute top-[-10%] right-[-5%] w-[500px] h-[500px] rounded-full bg-green-100 blur-[80px] opacity-70 animate-pulse" style="animation-duration: 4s;"></div>
    <div class="absolute bottom-[-10%] left-[-10%] w-[400px] h-[400px] rounded-full bg-amber-100 blur-[60px] opacity-60"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="lg:grid lg:grid-cols-12 lg:gap-16 items-center">
      
      <!-- Text Content -->
      <div class="lg:col-span-6 text-center lg:text-left mb-12 lg:mb-0 lg:-mt-10">
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-green-50 border border-green-100 text-green-700 font-semibold text-sm mb-6 shadow-sm hover:shadow-md transition-shadow">
          <span class="flex h-2 w-2 rounded-full bg-green-500 animate-ping"></span>
          Siente el cambio desde el primer mes
        </div>
        
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-slate-800 tracking-tight mb-6 leading-[1.1]">
          Consigue el Físico que Deseas <span class="text-transparent bg-clip-text bg-gradient-to-r from-green-600 to-green-400">Sin Aburrirte</span>
        </h1>
        
        <p class="text-lg sm:text-xl text-slate-600 mb-8 max-w-2xl mx-auto lg:mx-0 leading-relaxed font-light">
          Descubre una experiencia diferente cada mes. Tu <b>Nutribox</b> trae snacks premium, opciones sin azúcar y sorpresas fitness directo a tu puerta.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
          <button class="payment-btn group relative inline-flex items-center justify-center px-8 py-4 text-lg font-bold text-white bg-green-500 rounded-full overflow-hidden shadow-xl shadow-green-200 hover:scale-105 hover:shadow-2xl transition-all duration-300">
            <div class="absolute inset-0 w-full h-full bg-gradient-to-r from-transparent via-white/20 to-transparent -translate-x-full group-hover:animate-[shimmer_1.5s_infinite]"></div>
            <span class="mr-2">QUIERO MI NUTRIBOX AHORA</span>
            <Icon name="lucide:arrow-right" class="w-5 h-5 group-hover:translate-x-1 transition-transform" />
          </button>
        </div>

        <!-- Social Proof / Trust Indicators -->
        <div class="mt-10 pt-6 border-t border-slate-100 flex flex-col sm:flex-row items-center gap-6 justify-center lg:justify-start">
          <div class="flex -space-x-3">
            <div class="w-10 h-10 rounded-full border-2 border-white bg-slate-200 flex items-center justify-center text-xs font-bold overflow-hidden"><img src="https://i.pravatar.cc/100?img=1" alt="User" /></div>
            <div class="w-10 h-10 rounded-full border-2 border-white bg-slate-300 flex items-center justify-center text-xs font-bold overflow-hidden"><img src="https://i.pravatar.cc/100?img=2" alt="User" /></div>
            <div class="w-10 h-10 rounded-full border-2 border-white bg-slate-400 flex items-center justify-center text-xs font-bold overflow-hidden"><img src="https://i.pravatar.cc/100?img=3" alt="User" /></div>
            <div class="w-10 h-10 rounded-full border-2 border-white bg-green-100 flex items-center justify-center text-xs font-bold text-green-700">+1k</div>
          </div>
          <div class="text-sm font-medium text-slate-600">
            <div class="flex text-amber-400 mb-0.5">
              <Icon name="lucide:star" class="w-4 h-4 fill-current" />
              <Icon name="lucide:star" class="w-4 h-4 fill-current" />
              <Icon name="lucide:star" class="w-4 h-4 fill-current" />
              <Icon name="lucide:star" class="w-4 h-4 fill-current" />
              <Icon name="lucide:star" class="w-4 h-4 fill-current" />
            </div>
            Nutriboxers transformando su vida
          </div>
        </div>
      </div>

      <!-- Image / Visual Content -->
      <div class="lg:col-span-6 relative mt-12 lg:mt-0">
        <div class="relative w-full aspect-square max-w-md mx-auto">
          <!-- Main Box Image (Placeholder simulating a beautiful box) -->
          <div class="absolute inset-0 bg-gradient-to-tr from-green-500 to-green-300 rounded-[2rem] shadow-2xl transform rotate-3 hover:rotate-6 transition-transform duration-500 overflow-hidden flex flex-col items-center justify-center p-8 text-white">
            <div class="absolute top-0 right-0 w-32 h-32 bg-white/20 rounded-bl-full backdrop-blur-sm"></div>
            <div class="absolute bottom-0 left-0 w-24 h-24 bg-black/10 rounded-tr-full backdrop-blur-sm"></div>
            
            <Icon name="lucide:package-open" class="w-32 h-32 mb-4 drop-shadow-lg" />
            <h3 class="text-4xl font-black italic tracking-wider drop-shadow-md">NUTRIBOX</h3>
            <p class="mt-2 text-green-50 font-medium">Tu experiencia mensual</p>
          </div>

          <!-- Floating Elements -->
          <div class="absolute -top-6 -right-6 bg-white p-4 rounded-2xl shadow-xl animate-bounce" style="animation-duration: 3s;">
            <Icon name="lucide:apple" class="w-8 h-8 text-red-500" />
          </div>
          <div class="absolute bottom-10 -left-8 bg-white p-3 rounded-2xl shadow-xl animate-bounce" style="animation-duration: 4s; animation-delay: 1s;">
            <Icon name="lucide:dumbbell" class="w-10 h-10 text-slate-700" />
          </div>
          <div class="absolute -bottom-4 right-10 bg-amber-400 text-slate-900 font-bold px-4 py-2 rounded-xl shadow-lg transform -rotate-6">
            S/ 100 <span class="text-xs font-normal opacity-80">/mes</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes shimmer {
    100% {
      transform: translateX(100%);
    }
  }
</style>
