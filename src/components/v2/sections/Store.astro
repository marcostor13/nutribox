---
import NumberBlock from '../NumberBlock.astro';
import CtaButtonV2 from '../CtaButtonV2.astro';
import DuotonePhoto from '../DuotonePhoto.astro';
import DuotonePlaceholder from '../DuotonePlaceholder.astro';

const products = [
  { asset: 'store-mancuernas.jpg', label: 'Mancuernas' },
  { asset: 'store-bandas.jpg', label: 'Bandas elásticas', photoSrc: '/ilovepdf_images-extracted/img40.jpg' },
  { asset: 'store-tobilleras.jpg', label: 'Tobilleras' },
  { asset: 'store-mat.jpg', label: 'Mat de yoga', photoSrc: '/ilovepdf_images-extracted/img37.jpg' },
  { asset: 'store-kettlebells.jpg', label: 'Kettlebells' },
  { asset: 'store-accesorios.jpg', label: 'Accesorios fitness', photoSrc: '/real/store-accesorios.webp' },
];
---

<section id="store" class="bg-paper py-[clamp(5rem,12vh,9rem)]">
  <div class="mx-auto max-w-[1320px] px-5 sm:px-8">
    <div class="flex flex-col items-start justify-between gap-6 sm:flex-row sm:items-end">
      <NumberBlock num="04" labelEn="STORE" subtitle="Fitness Store" />
      <p class="max-w-xs font-mono text-xs text-steel" data-reveal>
        Todo lo que necesitas para entrenar desde casa.
      </p>
    </div>

    <div class="mt-16 grid grid-cols-2 gap-4 sm:gap-6 lg:grid-cols-3">
      {products.map((product, i) => (
        <div data-reveal data-reveal-index={i + 1}>
          {product.photoSrc ? (
            <DuotonePhoto
              src={product.photoSrc}
              alt={`${product.label} disponibles en Fitness Store BUNKERGYM`}
              ratio="1/1"
              tone={i % 2 === 0 ? 'acid' : 'blood'}
            />
          ) : (
            <DuotonePlaceholder
              alt={`${product.label} disponibles en Fitness Store BUNKERGYM`}
              asset={product.asset}
              ratio="1/1"
              tone={i % 2 === 0 ? 'acid' : 'blood'}
            />
          )}
          <p class="mt-3 font-display text-sm font-black uppercase tracking-tight">{product.label}</p>
        </div>
      ))}
    </div>

    <CtaButtonV2 variant="acid" waMessage="Hola, quiero ver la tienda de Fitness Store" class="mt-12">
      Ver tienda
    </CtaButtonV2>
  </div>
</section>
