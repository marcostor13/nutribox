---
import CtaButtonV2 from './CtaButtonV2.astro';
import DuotonePhoto from './DuotonePhoto.astro';
import DuotonePlaceholder from './DuotonePlaceholder.astro';

interface Group {
  heading?: string;
  items: string[];
}

interface Props {
  index: number;
  title: string;
  lead: string;
  groups: Group[];
  ctaLabel: string;
  waMessage: string;
  asset: string;
  alt: string;
  photoSrc?: string;
  tone?: 'acid' | 'blood';
  reverse?: boolean;
}

const {
  index,
  title,
  lead,
  groups,
  ctaLabel,
  waMessage,
  asset,
  alt,
  photoSrc,
  tone = 'acid',
  reverse = false,
} = Astro.props;

const toneText = tone === 'blood' ? 'text-blood' : 'text-acid';
---

<article
  class:list={[
    'grid grid-cols-1 items-center gap-10 lg:grid-cols-12 lg:gap-16',
    index > 0 && 'mt-24 border-t-[3px] border-void pt-24',
  ]}
>
  <div class:list={['lg:col-span-5', reverse && 'lg:order-2']} data-reveal>
    {photoSrc ? (
      <DuotonePhoto src={photoSrc} alt={alt} ratio="4/5" tone={tone} />
    ) : (
      <DuotonePlaceholder alt={alt} asset={asset} ratio="4/5" tone={tone} />
    )}
  </div>

  <div class:list={['lg:col-span-7', reverse && 'lg:order-1']} data-reveal>
    <span class={`font-mono text-xs font-bold uppercase tracking-[0.3em] ${toneText}`}>
      Servicio {String(index + 1).padStart(2, '0')}
    </span>
    <h3 class="mt-2 font-display text-h2 font-black uppercase leading-[0.95] tracking-tight">{title}</h3>
    <p class="mt-3 max-w-md font-display text-lg font-bold text-steel">{lead}</p>

    <div class="mt-8 grid grid-cols-1 gap-8 sm:grid-cols-2">
      {groups.map((group) => (
        <div>
          {group.heading && (
            <p class="mb-3 inline-block bg-void px-2 py-1 font-mono text-xs font-bold uppercase tracking-[0.14em] text-paper">
              {group.heading}
            </p>
          )}
          <ul class="flex flex-col gap-2.5">
            {group.items.map((item) => (
              <li class="flex items-start gap-2.5 font-display text-sm font-bold">
                <span class={`mt-0.5 ${toneText}`} aria-hidden="true">▸</span>
                {item}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <CtaButtonV2 variant={tone} waMessage={waMessage} class="mt-9">
      {ctaLabel}
    </CtaButtonV2>
  </div>
</article>
