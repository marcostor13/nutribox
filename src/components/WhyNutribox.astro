---
import { Icon } from 'astro-icon/components';

const audiences = [
  "Personas que quieren un cuerpo fitness",
  "Personas que quieren empezar hábitos saludables",
  "Quienes no tienen tiempo para planificar comidas",
  "Personas que aman cuidarse pero también disfrutar",
  "Diabéticos y veganos (versión especial*)"
];

const reasons = [
  { title: "Cero Aburrimiento", text: "No vuelves a aburrirte comiendo saludable. Descubres nuevos productos cada mes que mantienen la motivación viva." },
  { title: "Disciplina sin Esfuerzo", text: "Te ayuda a crear consistencia y disciplina sin sentir que estás haciendo un sacrificio." },
  { title: "Práctica y Divertida", text: "100% efectiva. Nosotros nos encargamos de la selección, tú solo de disfrutar el proceso." }
];
---

<section class="py-24 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      
      <!-- Right Side (Visual/Reasons) - Swapped visually on desktop -->
      <div class="order-2 lg:order-1 relative">
        <div class="absolute inset-0 bg-gradient-to-br from-green-100 to-transparent rounded-[3rem] -rotate-3 scale-105 z-0"></div>
        <div class="relative z-10 bg-white border border-slate-100 p-8 sm:p-10 rounded-[2.5rem] shadow-xl">
          <h3 class="text-3xl font-bold text-slate-800 mb-8 flex items-center gap-3">
            <Icon name="lucide:gem" class="w-8 h-8 text-green-500" />
            ¿Por qué <span class="text-green-500">Nutribox?</span>
          </h3>
          
          <div class="space-y-8">
            {reasons.map((reason, i) => (
              <div class="flex">
                <div class="flex-shrink-0 mt-1">
                  <div class="w-8 h-8 rounded-full bg-green-100 flex items-center justify-center text-green-600 font-bold text-sm">
                    {i + 1}
                  </div>
                </div>
                <div class="ml-4">
                  <h4 class="text-xl font-bold text-slate-800 mb-2">{reason.title}</h4>
                  <p class="text-slate-600 leading-relaxed">{reason.text}</p>
                </div>
              </div>
            ))}
          </div>

          <div class="mt-8 pt-6 border-t border-slate-100 flex items-start gap-4 bg-amber-50 rounded-2xl p-4">
            <Icon name="lucide:lightbulb" class="w-8 h-8 text-amber-500 flex-shrink-0" />
            <p class="text-sm font-medium text-slate-700 italic">
              El contenido cambia cada mes para mantener la motivación y la magia de la sorpresa siempre presentes.
            </p>
          </div>
        </div>
      </div>

      <!-- Left Side (Audience) -->
      <div class="order-1 lg:order-2">
        <h2 class="text-green-600 font-bold tracking-wider uppercase text-sm mb-3">Para Quién Es</h2>
        <h3 class="text-4xl md:text-5xl font-extrabold text-slate-800 mb-8 leading-tight">
          Diseñada para adaptarse a <span class="text-transparent bg-clip-text bg-gradient-to-r from-green-500 to-emerald-400">tu estilo de vida</span>
        </h3>
        
        <p class="text-lg text-slate-600 mb-10">
          No importa si estás empezando o si ya eres un experto. Nutribox es la herramienta que te faltaba para mantener la consistencia.
        </p>

        <ul class="space-y-5">
          {audiences.map(item => (
            <li class="flex items-center group">
              <div class="w-10 h-10 rounded-full bg-slate-50 flex items-center justify-center mr-4 group-hover:bg-green-50 group-hover:scale-110 transition-all">
                <Icon name="lucide:check" class="w-5 h-5 text-green-500" />
              </div>
              <span class="text-lg font-medium text-slate-700">{item}</span>
            </li>
          ))}
        </ul>

      </div>
    </div>
  </div>
</section>
