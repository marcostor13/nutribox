---
import SectionHeader from '../SectionHeader.astro';
import CtaButton from '../CtaButton.astro';
import Photo from '../Photo.astro';
import GhostLabel from '../GhostLabel.astro';

const gallery = [
  {
    src: '/ilovepdf_images-extracted/img54.jpg',
    label: 'Leggings & conjunto negro',
    ratio: '3/4',
    span: 'lg:col-span-4',
  },
  {
    src: '/ilovepdf_images-extracted/img48.jpg',
    label: 'Top deportivo y leggings flare',
    ratio: '4/5',
    span: 'lg:col-span-4',
  },
  {
    src: '/ilovepdf_images-extracted/img51.jpg',
    label: 'Conjunto premium',
    ratio: '4/5',
    span: 'lg:col-span-4',
  },
  {
    src: '/ilovepdf_images-extracted/img57.jpg',
    label: 'Casaca deportiva hombre',
    ratio: '4/5',
    span: 'lg:col-span-6',
  },
  {
    src: '/ilovepdf_images-extracted/img58.jpg',
    label: 'Polo oversize hombre',
    ratio: '4/5',
    span: 'lg:col-span-6',
  },
];

const items = ['Leggings', 'Tops deportivos', 'Casacas', 'Polos oversize', 'Conjuntos premium', 'Accesorios fitness'];
---

<section id="outfit" class="relative overflow-hidden bg-bone py-[clamp(5rem,12vh,9rem)]">
  <GhostLabel text="OUTFIT" />
  <div class="relative mx-auto max-w-[1240px] px-5 sm:px-8">
    <SectionHeader num="05" labelEn="OUTFIT" subtitle="Outfit Fitness" />

    <div class="mt-8 grid grid-cols-1 gap-8 lg:grid-cols-12 lg:items-end">
      <p class="max-w-md font-body text-lead text-ink/80 lg:col-span-6" data-reveal>
        Moda deportiva que combina estilo, comodidad y rendimiento. Colecciones para sentirte segura dentro y fuera
        del gimnasio.
      </p>
      <ul class="flex flex-wrap gap-x-6 gap-y-2 font-body text-sm text-concrete lg:col-span-6 lg:justify-end" data-reveal>
        {items.map((item) => (
          <li class="border-b border-signal/60 pb-0.5">{item}</li>
        ))}
      </ul>
    </div>

    <div class="mt-12 grid grid-cols-2 gap-4 sm:gap-6 lg:grid-cols-12">
      {gallery.map((g, i) => (
        <div class:list={['col-span-1', g.span]} data-reveal data-reveal-index={i + 1}>
          <Photo src={g.src} alt={`${g.label} — colección Outfit Fitness BUNKERGYM`} ratio={g.ratio} />
        </div>
      ))}
    </div>

    <div class="mt-12" data-reveal>
      <CtaButton variant="outline-dark" waMessage="Hola, quiero comprar outfit deportivo">
        Comprar outfit
      </CtaButton>
    </div>
  </div>
</section>
