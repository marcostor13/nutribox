---
import SectionHeader from '../SectionHeader.astro';
import Placeholder from '../Placeholder.astro';
import Photo from '../Photo.astro';
import GhostLabel from '../GhostLabel.astro';

const stats = [
  { target: 850, label: 'Miembros activos' },
  { target: 40, label: 'Clases por semana' },
  { target: 320, label: 'Transformaciones' },
];

const mosaic = [
  { src: '/real/community-outdoor.jpg', asset: 'community-01.jpg' },
  { src: '/real/community-indoor.jpg', asset: 'community-02.jpg' },
  { asset: 'community-03.jpg' },
  { asset: 'community-04.jpg' },
  { asset: 'community-05.jpg' },
];
---

<section id="comunidad" class="relative overflow-hidden bg-ink py-[clamp(5rem,12vh,9rem)] text-bone">
  <GhostLabel text="COMMUNITY" tone="dark" />
  <div class="relative mx-auto max-w-[1240px] px-5 sm:px-8">
    <SectionHeader num="08" labelEn="COMMUNITY" subtitle="Comunidad GioviFitness" theme="dark" />
    <p class="mt-6 max-w-xl font-body text-lead text-bone/80" data-reveal>
      Más que un programa. Una tribu que se apoya, crece y evoluciona junta.
    </p>

    <div class="mt-14 grid grid-cols-2 gap-3 sm:gap-4 lg:grid-cols-5">
      {mosaic.map((item, i) => (
        <div
          class:list={['col-span-1', i === 0 && 'col-span-2 row-span-2 lg:col-span-2']}
          data-reveal
          data-reveal-index={i + 1}
        >
          {item.src ? (
            <Photo src={item.src} alt="Comunidad GioviFitness entrenando en equipo" ratio={i === 0 ? '1/1' : '3/4'} />
          ) : (
            <Placeholder alt="Foto de la comunidad GioviFitness entrenando en equipo" asset={item.asset} tone="ink" ratio={i === 0 ? '1/1' : '3/4'} />
          )}
        </div>
      ))}
    </div>

    <div class="mt-16 grid grid-cols-1 gap-10 border-t border-bone/15 pt-12 sm:grid-cols-3">
      {stats.map((stat) => (
        <div class="text-center sm:text-left" data-reveal>
          <p class="font-display text-h2 font-black text-signal">
            <span data-count-to={stat.target}>0</span>+
          </p>
          <p class="mt-1 font-body text-sm uppercase tracking-[0.1em] text-bone/60">{stat.label}</p>
        </div>
      ))}
    </div>
  </div>
</section>
