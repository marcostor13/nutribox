---
import { Icon } from 'astro-icon/components';
import { waLink } from '../../../utils/whatsapp';
import GhostLabel from '../GhostLabel.astro';
---

<section class="relative overflow-hidden bg-signal py-[clamp(5rem,12vh,8rem)] text-signal-ink">
  <GhostLabel text="BUNKERGYM" />
  <div class="relative mx-auto max-w-[1240px] px-5 text-center sm:px-8" data-reveal>
    <h2 class="font-display text-h2 font-black uppercase leading-[1.02] tracking-tight">
      Tu nueva vida<br />empieza hoy
    </h2>
    <p class="mx-auto mt-5 max-w-md font-accent text-lg italic text-signal-ink/80">
      No esperes el momento perfecto. El momento perfecto es AHORA.
    </p>
    <a
      href={waLink('Hola, quiero transformar mi vida con BUNKERGYM.')}
      target="_blank"
      rel="noopener noreferrer"
      class="magnetic mt-9 inline-flex items-center gap-2 rounded-[4px] bg-ink px-8 py-4 font-body text-sm font-bold uppercase tracking-[0.08em] text-bone transition-colors hover:bg-ink-800 hover:shadow-bunker"
    >
      🚀 Quiero transformar mi vida
    </a>
  </div>
</section>

<footer class="bg-ink py-12 text-bone/70">
  <div class="mx-auto flex max-w-[1240px] flex-col items-center gap-6 px-5 text-center sm:flex-row sm:justify-between sm:text-left">
    <span class="font-display font-black uppercase tracking-tight text-bone">
      Bunker<span class="text-signal">Gym</span>
    </span>

    <div class="flex gap-5">
      <a href="#" class="hover:text-signal" aria-label="Instagram">
        <Icon name="lucide:instagram" class="h-5 w-5" />
      </a>
      <a
        href={waLink('Hola, tengo una consulta para BUNKERGYM.')}
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-signal"
        aria-label="WhatsApp"
      >
        <Icon name="lucide:message-circle" class="h-5 w-5" />
      </a>
    </div>

    <p class="font-body text-xs text-bone/50">&copy; {new Date().getFullYear()} BUNKERGYM by Giovifitness.</p>
  </div>
</footer>
