---
import SectionHeader from '../SectionHeader.astro';
import CtaButton from '../CtaButton.astro';
import Placeholder from '../Placeholder.astro';
import Photo from '../Photo.astro';
import GhostLabel from '../GhostLabel.astro';

const products = [
  { asset: 'store-mancuernas.jpg', label: 'Mancuernas' },
  { asset: 'store-bandas.jpg', label: 'Bandas elásticas', photoSrc: '/ilovepdf_images-extracted/img40.jpg' },
  { asset: 'store-tobilleras.jpg', label: 'Tobilleras' },
  { asset: 'store-mat.jpg', label: 'Mat de yoga', photoSrc: '/ilovepdf_images-extracted/img37.jpg' },
  { asset: 'store-kettlebells.jpg', label: 'Kettlebells' },
  { asset: 'store-accesorios.jpg', label: 'Accesorios fitness', photoSrc: '/real/store-accesorios.webp' },
];
---

<section id="store" class="relative overflow-hidden bg-bone-soft py-[clamp(5rem,12vh,9rem)]">
  <GhostLabel text="STORE" />
  <div class="relative mx-auto max-w-[1240px] px-5 sm:px-8">
    <div class="flex flex-col items-start justify-between gap-6 sm:flex-row sm:items-end">
      <SectionHeader num="04" labelEn="STORE" subtitle="Fitness Store" />
      <p class="max-w-xs font-body text-sm text-concrete" data-reveal>
        Todo lo que necesitas para entrenar desde casa.
      </p>
    </div>

    <div class="mt-14 grid grid-cols-2 gap-4 sm:gap-6 lg:grid-cols-3">
      {products.map((product, i) => (
        <div data-reveal data-reveal-index={i + 1} class="group">
          {product.photoSrc ? (
            <Photo src={product.photoSrc} alt={`${product.label} disponibles en Fitness Store GioviFitness`} ratio="1/1" />
          ) : (
            <Placeholder alt={`${product.label} disponibles en Fitness Store GioviFitness`} asset={product.asset} ratio="1/1" />
          )}
          <p class="mt-3 font-display text-sm font-semibold uppercase tracking-tight text-ink">{product.label}</p>
        </div>
      ))}
    </div>

    <div class="mt-12" data-reveal>
      <CtaButton variant="outline-dark" waMessage="Hola, quiero ver la tienda de Fitness Store">
        Ver tienda
      </CtaButton>
    </div>
  </div>
</section>
