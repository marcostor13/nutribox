---
import { Icon } from 'astro-icon/components';
import CtaButton from './CtaButton.astro';
import Placeholder from './Placeholder.astro';
import Photo from './Photo.astro';

interface Group {
  heading?: string;
  items: string[];
}

interface Props {
  index: number;
  title: string;
  lead: string;
  groups: Group[];
  ctaLabel: string;
  waMessage: string;
  asset: string;
  alt: string;
  photoSrc?: string;
  reverse?: boolean;
}

const { index, title, lead, groups, ctaLabel, waMessage, asset, alt, photoSrc, reverse = false } = Astro.props;
---

<article
  class:list={[
    'grid grid-cols-1 items-center gap-10 lg:grid-cols-12 lg:gap-16',
    index > 0 && 'mt-20 border-t border-line pt-20',
  ]}
>
  <div class:list={['lg:col-span-5', reverse && 'lg:order-2']} data-reveal>
    {photoSrc ? (
      <Photo src={photoSrc} alt={alt} ratio="4/5" />
    ) : (
      <Placeholder alt={alt} asset={asset} ratio="4/5" />
    )}
  </div>

  <div class:list={['lg:col-span-7', reverse && 'lg:order-1']} data-reveal>
    <h3 class="font-display text-h3 font-black uppercase tracking-tight text-ink">{title}</h3>
    <p class="mt-3 font-accent text-lg italic text-concrete">{lead}</p>

    <div class="mt-8 grid grid-cols-1 gap-8 sm:grid-cols-2">
      {groups.map((group) => (
        <div>
          {group.heading && (
            <p class="mb-3 font-body text-xs font-semibold uppercase tracking-[0.14em] text-signal-ink/70 bg-signal/0">
              <span class="border-b-2 border-signal pb-1">{group.heading}</span>
            </p>
          )}
          <ul class="flex flex-col gap-2.5">
            {group.items.map((item) => (
              <li class="flex items-start gap-2.5 font-body text-sm text-ink/80">
                <Icon name="lucide:check" class="mt-0.5 h-4 w-4 shrink-0 text-signal" />
                {item}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <CtaButton variant="outline-dark" waMessage={waMessage} class="mt-9">
      {ctaLabel}
    </CtaButton>
  </div>
</article>
